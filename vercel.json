{
  "version": 2,
  "builds": [
    {
      "src": "./index.js",
      "use": "@vercel/node",
      "config": { "maxPayload": "50mb" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
 "crons": [
    {
      "path": "/api/cron/generate-absen",
      "schedule": "* * * * *"
    }
  ]
}