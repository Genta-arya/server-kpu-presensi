generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SEKRETARIS
  K_SDM
  K_KUL
  K_RDT
  K_TEKHUM
  ADMIN_PPID
  USER
}

model Jabatan {
  id        String   @id @default(uuid())
  nama      String   @unique
  kode      String? // Opsional jika diperlukan
  users     User[]
  createdAt DateTime @default(now())
}

// 2. Model Unit Kerja (Tabel Terpisah)
model UnitKerja {
  id   String  @id @default(uuid())
  nama String  @unique
  kode String?

  createdAt     DateTime       @default(now())
  strukturUnits StrukturUnit[]
}

model StrukturUnit {
  id          String    @id @default(uuid())
  unitKerjaId String
  unitKerja   UnitKerja @relation(fields: [unitKerjaId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id]) // Prisma sekarang akan cocok dengan relasi di atas
  posisi      Posisi
}

enum Posisi {
  KASUBAG
  STAFF
  SEKRETARIS
  KEPALA_DIVISI
}

// 3. User sekarang terhubung dengan relasi ke Jabatan dan UnitKerja
model User {
  id           String    @id @default(uuid())
  username     String?   @unique
  name         String?
  nip          String?
  email        String?   @unique
  noHp         String?
  npwp         String?
  password     String
  status_mfa   Boolean   @default(false)
  security     String    @default("kpusekadau")
  status_login Boolean   @default(false)
  avatar       String?
  role         Role      @default(USER)
  token        String?   @db.MediumText
  mfa_secret   String?   @db.MediumText
  active       Boolean   @default(true)
  golonganId   String?
  golongan     Golongan? @relation(fields: [golonganId], references: [id])
  gaji         String?
  // Relasi
  jabatanId    String? // Foreign Key ke Jabatan
  jabatan      Jabatan?  @relation(fields: [jabatanId], references: [id])

  // unitKerjaId String? // Foreign Key ke UnitKerja
  // unitKerja   UnitKerja? @relation(fields: [unitKerjaId], references: [id])

  strukturUnit StrukturUnit[]

  Absens           Absen[]
  LaporanHarians   LaporanHarian[]
  ReportKesalahans ReportKesalahanData[]

  index     Int?
  secret    String?  @db.MediumText
  createdAt DateTime @default(now())
}

model ReportKesalahanData {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Field tambahan untuk kebutuhan laporan
  catatan   String   @db.Text
  status    String   @default("PENDING") // PENDING, PROCESSED, atau REJECTED
  createdAt DateTime @default(now())
}

model Golongan {
  id        String   @id @default(uuid())
  nama      String   @unique
  users     User[]
  createdAt DateTime @default(now())
}

model Notifikasi {
  id        String   @id @default(uuid())
  message   String   @db.MediumText
  status    String   @default("unread")
  createdAt DateTime @default(now())
}

model LaporanHarian {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  deskripsi String   @db.MediumText
  judul     String   @db.MediumText
  tanggal   DateTime
  createdAt DateTime @default(now())
}

model Absen {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  status     String   @default("tidak_hadir")
  img_ttd    String   @db.MediumText
  keterangan String?  @db.MediumText
  koordinat  String?
  createdAt  DateTime @default(now())

  @@unique([userId, createdAt])
}
